# ddharmon-ui environment.
# Loaded by systemd (EnvironmentFile=) in production; loaded by load_dotenv() when run manually.
# Copy to the repo root as `.env` and fill in. Keep this file OUT of git (.env is gitignored).

# --- LLM classify (optional) -----------------------------------------------------------------
# Required ONLY for classifyMode = sync | batch. The default classifyMode "none" runs the full
# cluster + value-subcluster + CDE-anchor pipeline with NO LLM call and NO key needed.
ANTHROPIC_API_KEY=sk-ant-...

# --- Clerk SSO gate + access control (optional) ----------------------------------------------
# The auth gate is INERT unless a JWKS source is configured, so local dev / the static build need none
# of this. A deploy turns it on purely via env. Two layers of vars: BACKEND (runtime, this file, read by
# the FastAPI app) and FRONTEND (build-time, read by `vite build` — set them in the build environment).
#
# BACKEND (runtime):
#   CLERK_ISSUER — the Clerk instance issuer URL; JWKS is derived as <issuer>/.well-known/jwks.json.
#     Setting this ENABLES the gate: every /api/harmonize/* call (except public demo paths) needs a valid
#     Clerk session JWT. Unset -> gate off (anonymous, wide open).
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev
#   CLERK_EMAIL_CLAIM — the session-token claim carrying the user's email (default "email"). Configure a
#     Clerk custom session claim: {"email": "{{user.primary_email_address}}"}.
# CLERK_EMAIL_CLAIM=email
#   DDHARMON_ALLOWED_EMAIL_DOMAINS — comma-separated email-domain allowlist. UNSET or "*" = any signed-in
#     user (the default, for external collaborators). Set it to lock the API to specific domains — the
#     backend rejects (403) any verified token whose email domain isn't listed. This is the server-side
#     half of the PH-only dev-channel lock (defense in depth; don't rely on Clerk config alone).
# DDHARMON_ALLOWED_EMAIL_DOMAINS=phenomehealth.org
#   DDHARMON_UI_ALLOWED_ORIGINS — comma-separated CORS origins (default localhost dev). Set to the deploy
#     origin(s), e.g. https://dev.ddharmon.io for the dev channel.
# DDHARMON_UI_ALLOWED_ORIGINS=https://dev.ddharmon.io
#
# FRONTEND (build-time; consumed by `vite build`, NOT the backend):
#   VITE_CLERK_PUBLISHABLE_KEY — Clerk publishable key. Present -> the SPA shows a sign-in wall; absent ->
#     transparent pass-through (static/marketing build).
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
#   VITE_ALLOW_GUEST — set to "false" to REMOVE the "explore the demo without signing in" bypass, making
#     sign-in mandatory (the PH-only dev channel). Unset/anything-else keeps guest demo mode (prod).
# VITE_ALLOW_GUEST=false

# --- optional overrides (defaults shown as comments) -----------------------------------------
# Directory holding the CDE catalog flat TSVs (cdeSet = endorsed -> nih_endorsed_flat.tsv,
# cdeSet = full -> all_cdes_flat.tsv). The catalog is NOT in this repo (data/cde/ is gitignored)
# — see deploy/README.md for how to put it on the server. Default: <repo>/data/cde
# DDHARMON_CDE_DIR=/home/ubuntu/ddharmon-ui/data/cde

# Scratch dir for per-job uploads + Anthropic Batch artifacts (one subdir per jobId).
# Default: <repo>/.ddharmon_ui
# DDHARMON_UI_WORK=/home/ubuntu/ddharmon-ui/.ddharmon_ui

# Embedding model cache. Set in the systemd unit so the first-run download (~420MB,
# all-mpnet-base-v2) lands inside the deploy dir (ProtectSystem=strict); override here
# only if you relocate the cache.
# HF_HOME=/home/ubuntu/ddharmon-ui/.cache/huggingface
# SENTENCE_TRANSFORMERS_HOME=/home/ubuntu/ddharmon-ui/.cache/sentence-transformers
